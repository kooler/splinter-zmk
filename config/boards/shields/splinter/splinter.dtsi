 *
 * Splinter 65% Split Keyboard - Shared Configuration
 * Matrix: 10 rows x 7 columns (5 rows per side)
 * 70 keys total (35 per side)
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
    };

    /*
     * Key transform mapping physical keys to matrix positions
     * Left half: rows 0-4, Right half: rows 5-9
     *
     * Physical Layout:
     * в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ   в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
     * в”ӮESCв”Ӯ 1 в”Ӯ 2 в”Ӯ 3 в”Ӯ 4 в”Ӯ 5 в”Ӯ 6 в”Ӯ   в”Ӯ 7 в”Ӯ 8 в”Ӯ 9 в”Ӯ 0 в”Ӯ - в”Ӯ = в”Ӯ BKSPC в”Ӯ
     * в”ңв”Җв”Җв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҳ в”Ңв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Ө
     * в”Ӯ TAB в”Ӯ Q в”Ӯ W в”Ӯ E в”Ӯ R в”Ӯ T в”Ӯ   в”Ӯ Y в”Ӯ U в”Ӯ I в”Ӯ O в”Ӯ P в”Ӯ [ в”Ӯ ] в”Ӯ  \  в”Ӯ
     * в”ңв”Җв”Җв”Җв”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”җ  в””в”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Ө
     * в”Ӯ CAPS в”Ӯ A в”Ӯ S в”Ӯ D в”Ӯ F в”Ӯ G в”Ӯ   в”Ӯ H в”Ӯ J в”Ӯ K в”Ӯ L в”Ӯ ; в”Ӯ ' в”Ӯ  ENTER в”Ӯ
     * в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”җ в””в”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Ө
     * в”Ӯ SHIFT  в”Ӯ ` в”Ӯ Z в”Ӯ X в”Ӯ C в”Ӯ V в”Ӯ B в”Ӯ N в”Ӯ M в”Ӯ , в”Ӯ . в”Ӯ / в”ӮUP в”Ӯ DEL  в”Ӯ
     * в”ңв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”ҙв”¬в”Җв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”ҙв”Җв”¬в”Җв”Җв”Җв”Җв”Ө
     * в”ӮCTRLв”ӮALT в”ӮGUI в”Ӯ   SPACE   в”ӮFN в”Ӯ   SPACE   в”ӮFN в”ӮHOMв”ӮвҶҗ  в”Ӯ вҶ“ в”Ӯ вҶ’  в”ӮENTв”Ӯ
     * в””в”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”ҳ
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <5>;
        map = <
            // Row 0: Number row
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)    RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13)
            // Row 1: QWERTY row
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6)    RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            // Row 2: Home row
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6)    RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
            // Row 3: Bottom alpha row
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6)    RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13)
            // Row 4: Bottom row (modifiers and space)
            RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6)    RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,12) RC(4,13)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        keys = <
            // Row 0: Number row (ESC, 1-6, 7-0, -, =, BSPC)
            &key_physical_attrs 100 100    0    0 0 0 0
            &key_physical_attrs 100 100  100    0 0 0 0
            &key_physical_attrs 100 100  200    0 0 0 0
            &key_physical_attrs 100 100  300    0 0 0 0
            &key_physical_attrs 100 100  400    0 0 0 0
            &key_physical_attrs 100 100  500    0 0 0 0
            &key_physical_attrs 100 100  600    0 0 0 0
            &key_physical_attrs 100 100  800    0 0 0 0
            &key_physical_attrs 100 100  900    0 0 0 0
            &key_physical_attrs 100 100 1000    0 0 0 0
            &key_physical_attrs 100 100 1100    0 0 0 0
            &key_physical_attrs 100 100 1200    0 0 0 0
            &key_physical_attrs 100 100 1300    0 0 0 0
            &key_physical_attrs 100 100 1400    0 0 0 0
            // Row 1: QWERTY row (TAB, Q-T, none, Y-P, [, ])
            &key_physical_attrs 100 100    0  100 0 0 0
            &key_physical_attrs 100 100  100  100 0 0 0
            &key_physical_attrs 100 100  200  100 0 0 0
            &key_physical_attrs 100 100  300  100 0 0 0
            &key_physical_attrs 100 100  400  100 0 0 0
            &key_physical_attrs 100 100  500  100 0 0 0
            &key_physical_attrs 100 100  600  100 0 0 0
            &key_physical_attrs 100 100  800  100 0 0 0
            &key_physical_attrs 100 100  900  100 0 0 0
            &key_physical_attrs 100 100 1000  100 0 0 0
            &key_physical_attrs 100 100 1100  100 0 0 0
            &key_physical_attrs 100 100 1200  100 0 0 0
            &key_physical_attrs 100 100 1300  100 0 0 0
            &key_physical_attrs 100 100 1400  100 0 0 0
            // Row 2: Home row (CAPS, A-G, none, H-L, ;, ', BSLH)
            &key_physical_attrs 100 100    0  200 0 0 0
            &key_physical_attrs 100 100  100  200 0 0 0
            &key_physical_attrs 100 100  200  200 0 0 0
            &key_physical_attrs 100 100  300  200 0 0 0
            &key_physical_attrs 100 100  400  200 0 0 0
            &key_physical_attrs 100 100  500  200 0 0 0
            &key_physical_attrs 100 100  600  200 0 0 0
            &key_physical_attrs 100 100  800  200 0 0 0
            &key_physical_attrs 100 100  900  200 0 0 0
            &key_physical_attrs 100 100 1000  200 0 0 0
            &key_physical_attrs 100 100 1100  200 0 0 0
            &key_physical_attrs 100 100 1200  200 0 0 0
            &key_physical_attrs 100 100 1300  200 0 0 0
            &key_physical_attrs 100 100 1400  200 0 0 0
            // Row 3: Bottom alpha row (SHIFT, `, Z-V, B, N-M, ,, ., /, UP, DEL)
            &key_physical_attrs 100 100    0  300 0 0 0
            &key_physical_attrs 100 100  100  300 0 0 0
            &key_physical_attrs 100 100  200  300 0 0 0
            &key_physical_attrs 100 100  300  300 0 0 0
            &key_physical_attrs 100 100  400  300 0 0 0
            &key_physical_attrs 100 100  500  300 0 0 0
            &key_physical_attrs 100 100  600  300 0 0 0
            &key_physical_attrs 100 100  800  300 0 0 0
            &key_physical_attrs 100 100  900  300 0 0 0
            &key_physical_attrs 100 100 1000  300 0 0 0
            &key_physical_attrs 100 100 1100  300 0 0 0
            &key_physical_attrs 100 100 1200  300 0 0 0
            &key_physical_attrs 100 100 1300  300 0 0 0
            &key_physical_attrs 100 100 1400  300 0 0 0
            // Row 4: Bottom row (CTRL, ALT, GUI, SPACE, none, none, FN, SPACE, FN, HOME, arrows, ENTER)
            &key_physical_attrs 100 100    0  400 0 0 0
            &key_physical_attrs 100 100  100  400 0 0 0
            &key_physical_attrs 100 100  200  400 0 0 0
            &key_physical_attrs 100 100  300  400 0 0 0
            &key_physical_attrs 100 100  400  400 0 0 0
            &key_physical_attrs 100 100  500  400 0 0 0
            &key_physical_attrs 100 100  600  400 0 0 0
            &key_physical_attrs 100 100  800  400 0 0 0
            &key_physical_attrs 100 100  900  400 0 0 0
            &key_physical_attrs 100 100 1000  400 0 0 0
            &key_physical_attrs 100 100 1100  400 0 0 0
            &key_physical_attrs 100 100 1200  400 0 0 0
            &key_physical_attrs 100 100 1300  400 0 0 0
            &key_physical_attrs 100 100 1400  400 0 0 0
        >;
    };
};
